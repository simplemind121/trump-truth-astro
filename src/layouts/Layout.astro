---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #f5f7fb;
        --panel: #ffffff;
        --panel-soft: #f8fbff;
        --text: #162033;
        --muted: #6b7280;
        --line: #e6ecf5;
        --accent: #2563eb;
        --accent-soft: #eaf2ff;
        --orange: #f36f21;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial,
          "PingFang SC", "Microsoft YaHei", sans-serif;
        background: linear-gradient(180deg, #fbfdff 0%, #f3f7fd 100%);
        color: var(--text);
      }

      .wrap {
        width: min(1080px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 28px 0 40px;
      }

      .hero {
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--shadow);
        padding: 26px 24px 22px;
        margin-bottom: 18px;
      }

      .topnav {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }

      .navchip {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid var(--line);
        font-size: 13px;
        color: #374151;
        text-decoration: none;
        transition: 0.15s ease;
      }

      .navchip:hover {
        background: var(--accent-soft);
        color: var(--accent);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 13px;
        font-weight: 700;
      }

      .eyebrow::before {
        content: "📰";
      }

      h1 {
        margin: 14px 0 10px;
        font-size: 38px;
        line-height: 1.08;
        letter-spacing: -0.03em;
      }

      .sub {
        color: var(--muted);
        font-size: 15px;
        line-height: 1.75;
        max-width: 760px;
      }

      .hero-row {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: flex-end;
        flex-wrap: wrap;
      }

      .hero-meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
      }

      .toggle-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .toggle-btn {
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--muted);
        font-size: 13px;
        cursor: pointer;
        transition: 0.15s ease;
      }

      .toggle-btn.active {
        background: #162033;
        color: #fff;
        border-color: #162033;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        min-width: 260px;
      }

      .stat {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 16px 18px;
        box-shadow: var(--shadow);
      }

      .stat-label {
        font-size: 12px;
        color: var(--muted);
      }

      .stat-value {
        margin-top: 8px;
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .stat-sub {
        margin-top: 6px;
        font-size: 12px;
        color: var(--muted);
      }

      .error {
        display: none;
        margin: 0 0 14px;
        padding: 14px 16px;
        border-radius: 18px;
        background: #fff4f4;
        border: 1px solid #ffd5d5;
        color: #b42318;
      }

      .error.show {
        display: block;
      }

      .timeline {
        position: relative;
        padding-left: 34px;
      }

      .timeline::before {
        content: "";
        position: absolute;
        left: 14px;
        top: 8px;
        bottom: 8px;
        width: 2px;
        background: linear-gradient(180deg, #cfe0ff 0%, #dce8f8 100%);
      }

      .item {
        position: relative;
        margin-bottom: 16px;
      }

      .item:last-child {
        margin-bottom: 0;
      }

      .dot {
        position: absolute;
        left: -34px;
        top: 24px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f7cff, #2563eb);
        box-shadow: 0 0 0 5px rgba(37, 99, 235, 0.12);
      }

      .card {
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 18px 18px 16px;
        box-shadow: var(--shadow);
      }

      .card-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
      }

      .profile {
        display: flex;
        gap: 12px;
        align-items: center;
      }

      .avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #f9a14a, #f36f21);
        color: #fff;
        font-weight: 800;
        box-shadow: 0 10px 24px rgba(243, 111, 33, 0.22);
        overflow: hidden;
        flex-shrink: 0;
      }

      .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .name {
        font-size: 16px;
        font-weight: 800;
      }

      .handle {
        margin-top: 3px;
        font-size: 12px;
        color: var(--muted);
      }

      .time {
        font-size: 12px;
        color: var(--muted);
        white-space: nowrap;
      }

      .body {
        margin-top: 14px;
        font-size: 16px;
        line-height: 1.8;
        color: #1f2937;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .body.is-original {
        color: #334155;
      }

      .meta {
        margin-top: 14px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .tag {
        padding: 7px 10px;
        border-radius: 999px;
        background: var(--accent-soft);
        border: 1px solid #d8e6ff;
        color: #275ccf;
        font-size: 12px;
        font-weight: 700;
      }

      .media {
        margin-top: 14px;
        display: grid;
        gap: 10px;
      }

      .media img,
      .media video {
        width: 100%;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: #f5f7fb;
        display: block;
      }

      .media video {
        max-height: 420px;
      }

      .link-row {
        margin-top: 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
      }

      .origin-link {
        color: var(--orange);
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: 0.15s ease;
      }

      .origin-link:hover {
        opacity: 0.8;
      }

      .origin-link::after {
        content: " ↗";
      }

      @media (max-width: 900px) {
        .hero-row {
          align-items: flex-start;
        }

        .stats {
          width: 100%;
        }

        .timeline {
          padding-left: 26px;
        }

        .timeline::before {
          left: 10px;
        }

        .dot {
          left: -26px;
        }
      }

      @media (max-width: 560px) {
        .wrap {
          width: calc(100vw - 14px);
          padding: 12px 0 20px;
        }

        .hero {
          padding: 16px 14px 14px;
          border-radius: 20px;
          margin-bottom: 10px;
        }

        .topnav {
          gap: 8px;
          margin-bottom: 8px;
        }

        .navchip {
          font-size: 12px;
          padding: 7px 10px;
        }

        .eyebrow {
          font-size: 12px;
          padding: 7px 10px;
        }

        h1 {
          font-size: 25px;
          line-height: 1.16;
          margin: 8px 0 8px;
        }

        .sub {
          font-size: 13px;
          line-height: 1.62;
        }

        .hero-meta {
          gap: 8px;
          margin-top: 8px;
        }

        .toggle-btn {
          font-size: 12px;
          padding: 7px 10px;
        }

        .stats {
          gap: 8px;
          grid-template-columns: 1fr 1fr;
          min-width: 0;
        }

        .stat {
          padding: 12px;
          border-radius: 16px;
        }

        .stat-value {
          font-size: 20px;
        }

        .stat-sub {
          font-size: 11px;
          line-height: 1.5;
        }

        .timeline {
          padding-left: 20px;
        }

        .timeline::before {
          left: 7px;
        }

        .dot {
          left: -20px;
          top: 18px;
          width: 11px;
          height: 11px;
          box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
        }

        .card {
          padding: 12px 12px 10px;
          border-radius: 18px;
        }

        .card-top {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
        }

        .profile {
          gap: 10px;
        }

        .avatar {
          width: 38px;
          height: 38px;
        }

        .time {
          font-size: 11px;
        }

        .body {
          font-size: 14px;
          line-height: 1.68;
          margin-top: 12px;
        }

        .meta {
          gap: 6px;
          margin-top: 12px;
        }

        .tag {
          font-size: 11px;
          padding: 6px 8px;
        }

        .media {
          margin-top: 12px;
        }

        .link-row {
          margin-top: 12px;
        }

        .origin-link {
          font-size: 12px;
        }
      }

      @media (max-width: 380px) {
        .stats {
          grid-template-columns: 1fr;
        }

        h1 {
          font-size: 23px;
        }

        .card {
          padding: 11px 11px 10px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
